# Copy this file to .env.local and fill in your Supabase project values.
# Find these in Supabase Dashboard -> Project Settings -> API.
# The anon key is safe to expose to the browser (protected by Row-Level Security).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only key for admin/seed scripts. NEVER expose to the browser and NEVER commit .env.local.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Automation ------------------------------------------------------------
# Bearer token Vercel Cron sends to /api/cron/daily. If UNSET the endpoint 401s
# and ALL nightly automation is dead — renewals, reminders, SLA sweeps and lead
# digests. Set the same value in Vercel env AND in the cron job's header.
CRON_SECRET=generate-a-long-random-string

# ---- Website lead capture --------------------------------------------------
# Shared key your website sends as the X-Cureocity-Key header when POSTing to
# /api/leads/website. Unset = the endpoint rejects everything (fail closed).
WEBSITE_LEAD_SECRET=generate-a-different-long-random-string

# Who owns leads that arrive from the website. One staff id, or several
# comma-separated to share them out — the lead goes to whoever currently has
# fewer open leads, so it self-corrects when someone is on leave.
# Without it the lead is still captured but arrives unowned.
WEBSITE_LEAD_OWNER=s1,thamanna-nazer

# ---- Email (Resend) --------------------------------------------------------
# Unset = sendEmail() returns "skipped" but still writes to email_log, so the
# log will look like mail was sent when nothing left the building.
RESEND_API_KEY=
EMAIL_FROM=Cureocity <no-reply@cureo.city>

# ---- Instagram / Facebook Lead Ads ------------------------------------------
# Webhook receiver at /api/leads/meta. All three must be set or it stays inert
# (GET handshake fails, POST rejects on signature). See docs/meta-lead-capture.md
#
# A string YOU choose, entered in the Meta app's webhook config as the Verify
# Token; the app echoes Meta's challenge only when it matches.
META_VERIFY_TOKEN=choose-any-random-string
# The Meta App Secret (App Settings -> Basic). Used to verify X-Hub-Signature-256.
META_APP_SECRET=
# A long-lived Page access token with leads_retrieval. Used to fetch the actual
# lead answers from the Graph API — the webhook only sends an id.
META_PAGE_ACCESS_TOKEN=
# Who owns Instagram-ad leads. Same format as WEBSITE_LEAD_OWNER: one staff id
# or several comma-separated for least-loaded rotation.
META_LEAD_OWNER=s1,thamanna-nazer

# ---- Wati (WhatsApp) lead capture -------------------------------------------
# Webhook receiver at /api/leads/wati. Fails closed: without the secret set,
# every request is rejected. See docs/wati-lead-capture.md
#
# A string YOU choose. In Wati (Connectors -> Webhooks) add a header
# Authorization = Bearer <this value>; the endpoint checks it constant-time.
WATI_WEBHOOK_SECRET=
# Who owns WhatsApp leads. Same format as WEBSITE_LEAD_OWNER: one staff id or
# several comma-separated for least-loaded rotation.
WATI_LEAD_OWNER=s1,thamanna-nazer
